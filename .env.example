# AgriTrack frontend — copy to `.env` (not committed). See also config.js + vite.config.js.
#
# --- Local development (backend on this machine) ---
# Turn on API sync. Leave VITE_API_URL empty so requests go to /api on the Vite dev server and
# vite.config.js proxies them to your Nest app (default: http://127.0.0.1:5000; must match API PORT).
VITE_USE_API=true
VITE_DEV_API_PROXY=http://127.0.0.1:5000
#
# Optional: call the API directly (skips proxy). Same as proxy target for most setups:
VITE_API_URL=https://farm-monitoring.onrender.com
#
# --- After you deploy the backend (Vercel, etc.) ---
# Set in the host’s environment and rebuild the frontend (Vite bakes VITE_* at build time):
# VITE_USE_API=true
# VITE_API_URL=https://your-api.example.com
#
# Show Farmer / Trader quick-login with API (default: only when Vite dev). Production: usually omit.
# VITE_SHOW_QUICK_LOGIN=true
# (legacy alias, still honored: VITE_SHOW_DEMO_QUICK_LOGIN=true)
#
# --- Upgrade page (optional fallbacks when API is off; match API BILLING_* in production) ---
# VITE_STRIPE_ENABLED=true
# VITE_BILLING_FEATURED_UGX=100000
# VITE_BILLING_PREMIUM_UGX=180000
#
# --- Marketplace / Sui (optional) ---
# VITE_PLATFORM_FEE_BPS=100
# VITE_PLATFORM_ACCOUNT_NAME=Your platform name
# VITE_SUI_NETWORK=devnet
